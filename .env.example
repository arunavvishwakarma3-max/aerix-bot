BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# Owner Discord ID — required for /eval, /broadcast, /servers, /blacklist, /whitelist
# Get it: Discord Settings > Advanced > Developer Mode ON > Right-click your name > Copy ID
# OWNER_ID=123456789012345678

# Set this for instant guild-specific deployment (dev), or leave empty for global (takes ~1hr)
GUILD_ID=

# Database path (for Render persistent disk)
DB_PATH=/data/bot.db
